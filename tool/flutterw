#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PATH="$ROOT_DIR/.local-bin:$ROOT_DIR/.tools/flutter/bin:$PATH"

if [[ -d "$ROOT_DIR/.tools/android-sdk" ]]; then
  export ANDROID_SDK_ROOT="$ROOT_DIR/.tools/android-sdk"
fi

if [[ -d "$ROOT_DIR/.tools/jdk/jdk-17.0.18+8" ]]; then
  export JAVA_HOME="$ROOT_DIR/.tools/jdk/jdk-17.0.18+8"
  export PATH="$JAVA_HOME/bin:$PATH"
fi

exec flutter "$@"
